{% extends 'base.html.twig' %}

{% block title %}归还检查 - 租单#{{ rental.id }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="card">
    <h2>🔍 归还检查 - 租单 #{{ rental.id }}</h2>

    <div style="padding:15px;background:#f8f9fa;border-radius:6px;margin-bottom:20px;">
        <div class="detail-grid">
            <div class="detail-item">
                <div class="label">服装</div>
                <div class="value">{{ rental.dress.name }} ({{ rental.dress.size }}/{{ rental.dress.color }})</div>
            </div>
            <div class="detail-item">
                <div class="label">客户</div>
                <div class="value">{{ rental.customer.name }} ({{ rental.customer.phone }})</div>
            </div>
            <div class="detail-item">
                <div class="label">出租日期</div>
                <div class="value">{{ rental.rentalDate|date('Y-m-d') }}</div>
            </div>
            <div class="detail-item">
                <div class="label">应还日期</div>
                <div class="value">
                    {{ rental.dueDate|date('Y-m-d') }}
                    {% if rental.isOverdue %}
                        <span class="badge badge-overdue">逾期 {{ rental.overdueDays }} 天</span>
                    {% endif %}
                </div>
            </div>
            <div class="detail-item">
                <div class="label">收取押金</div>
                <div class="value" style="font-size:18px;color:#8B0000;"><strong>¥{{ rental.depositPaid }}</strong></div>
            </div>
            <div class="detail-item">
                <div class="label">租赁天数</div>
                <div class="value">{{ rental.rentalDays }} 天</div>
            </div>
        </div>
    </div>

    {% if rental.status == 'closed' %}
    <div class="alert alert-danger">该租单已结单，无法重复操作！</div>
    {% else %}
    <form method="post">
        <h3 style="font-size:16px;margin:20px 0 15px;border-bottom:1px solid #eee;padding-bottom:10px;">📅 归还信息</h3>
        <div class="form-row">
            <div class="form-group">
                <label>归还日期</label>
                <input type="date" name="return_date" value="{{ today }}">
            </div>
            <div class="form-group">
                <label style="display:flex;align-items:center;gap:8px;margin-top:30px;">
                    <input type="checkbox" name="needs_cleaning" value="1" checked style="width:auto;">
                    需要清洗（默认勾选，归还后自动排清洗）
                </label>
            </div>
        </div>

        <h3 style="font-size:16px;margin:20px 0 15px;border-bottom:1px solid #eee;padding-bottom:10px;">
            💰 损坏检查（扣款从押金扣除，总额不超过押金 ¥{{ rental.depositPaid }}）
        </h3>

        <div id="damage-records">
            <div class="damage-row">
                <div class="form-group" style="flex:2;">
                    <label>损坏描述</label>
                    <input type="text" name="damage_description[]" placeholder="例如：裙摆破洞、污渍等">
                </div>
                <div class="form-group" style="flex:1;">
                    <label>扣款金额 (¥)</label>
                    <input type="number" step="0.01" min="0" name="damage_amount[]" placeholder="0.00">
                </div>
            </div>
        </div>

        <div class="add-btn">
            <button type="button" class="btn btn-secondary btn-sm" onclick="addDamageRow()">+ 添加一项损坏</button>
        </div>

        <div style="margin-top:30px;padding:15px;background:#fff8e1;border-radius:6px;border:1px solid #ffe082;">
            <div style="display:flex;justify-content:space-between;align-items:center;">
                <div>
                    <div>押金：¥{{ rental.depositPaid }}</div>
                    <div>预计退还：<span id="preview-refund" style="font-size:18px;color:#28a745;font-weight:bold;">¥{{ rental.depositPaid }}</span></div>
                </div>
                <button type="submit" class="btn btn-primary" style="font-size:16px;padding:10px 30px;">确认归还</button>
            </div>
        </div>
    </form>
    {% endif %}
</div>

<script>
function addDamageRow() {
    const container = document.getElementById('damage-records');
    const row = document.createElement('div');
    row.className = 'damage-row';
    row.innerHTML = `
        <div class="form-group" style="flex:2;">
            <label>损坏描述</label>
            <input type="text" name="damage_description[]" placeholder="例如：裙摆破洞、污渍等">
        </div>
        <div class="form-group" style="flex:1;">
            <label>扣款金额 (¥)</label>
            <input type="number" step="0.01" min="0" name="damage_amount[]" placeholder="0.00">
        </div>
        <button type="button" class="btn btn-danger btn-sm" style="margin-bottom:0;" onclick="this.parentElement.remove();updateRefund();">删除</button>
    `;
    container.appendChild(row);
    row.querySelectorAll('input').forEach(input => {
        input.addEventListener('input', updateRefund);
    });
}

function updateRefund() {
    const deposit = {{ rental.depositPaid }};
    let total = 0;
    document.querySelectorAll('input[name="damage_amount[]"]').forEach(input => {
        const val = parseFloat(input.value) || 0;
        if (val > 0) total += val;
    });
    const refund = Math.max(0, deposit - total);
    document.getElementById('preview-refund').textContent = '¥' + refund.toFixed(2);
    if (total > deposit) {
        document.getElementById('preview-refund').style.color = '#dc3545';
        document.getElementById('preview-refund').textContent += ' (扣款超过押金！)';
    } else {
        document.getElementById('preview-refund').style.color = '#28a745';
    }
}

document.querySelectorAll('input[name="damage_amount[]"]').forEach(input => {
    input.addEventListener('input', updateRefund);
});
</script>
{% endblock %}
