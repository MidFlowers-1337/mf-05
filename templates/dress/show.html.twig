{% extends 'base.html.twig' %}

{% block title %}{{ dress.name }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="card">
    <h2 style="display:flex;justify-content:space-between;align-items:center;">
        👗 {{ dress.name }}
        <div>
            <a href="{{ path('app_dress_edit', {id: dress.id}) }}" class="btn btn-secondary btn-sm">编辑</a>
            {% if dress.status == 'available' %}
                <a href="{{ path('app_rental_new', {dressId: dress.id}) }}" class="btn btn-primary btn-sm">出租</a>
            {% endif %}
            {% if dress.status == 'available' or dress.status == 'damaged' %}
            <form method="post" action="{{ path('app_dress_delete', {id: dress.id}) }}" style="display:inline" onsubmit="return confirm('确认删除这件服装？')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ dress.id) }}">
                <button type="submit" class="btn btn-danger btn-sm">删除</button>
            </form>
            {% endif %}
        </div>
    </h2>

    <div style="display:flex;gap:30px;">
        <div>
            {% if dress.photo %}
                <img src="{{ dress.photo }}" alt="{{ dress.name }}" style="width:250px;border-radius:4px;">
            {% else %}
                <div class="photo-placeholder" style="width:250px;height:300px;">暂无照片</div>
            {% endif %}
        </div>
        <div style="flex:1;">
            <div class="detail-grid">
                <div class="detail-item">
                    <div class="label">服装编号</div>
                    <div class="value">#{{ dress.id }}</div>
                </div>
                <div class="detail-item">
                    <div class="label">当前状态</div>
                    <div class="value">
                        {% if dress.status == 'available' %}
                            <span class="badge badge-available">{{ dress.statusLabel }}</span>
                        {% elseif dress.status == 'rented' %}
                            <span class="badge badge-rented">{{ dress.statusLabel }}</span>
                        {% elseif dress.status == 'cleaning' %}
                            <span class="badge badge-cleaning">{{ dress.statusLabel }}</span>
                        {% else %}
                            <span class="badge badge-damaged">{{ dress.statusLabel }}</span>
                        {% endif %}
                    </div>
                </div>
                <div class="detail-item">
                    <div class="label">款名</div>
                    <div class="value">{{ dress.name }}</div>
                </div>
                <div class="detail-item">
                    <div class="label">尺码</div>
                    <div class="value">{{ dress.size }}</div>
                </div>
                <div class="detail-item">
                    <div class="label">颜色</div>
                    <div class="value">{{ dress.color }}</div>
                </div>
                <div class="detail-item">
                    <div class="label">买价</div>
                    <div class="value">¥{{ dress.purchasePrice }}</div>
                </div>
                <div class="detail-item">
                    <div class="label">押金</div>
                    <div class="value">¥{{ dress.deposit }}</div>
                </div>
                <div class="detail-item">
                    <div class="label">日租金</div>
                    <div class="value">¥{{ dress.dailyRate }}/天</div>
                </div>
                <div class="detail-item">
                    <div class="label">登记日期</div>
                    <div class="value">{{ dress.createdAt|date('Y-m-d H:i') }}</div>
                </div>
                <div class="detail-item">
                    <div class="label">累计出租</div>
                    <div class="value">{{ dress.rentalCount }}次</div>
                </div>
            </div>

            {% if dress.status == 'damaged' %}
                <div style="margin-top:20px;">
                    <form method="post" action="{{ path('app_cleaning_mark_ready', {dressId: dress.id}) }}" onsubmit="return confirm('确认已修复并送去清洗？')">
                        <input type="hidden" name="_token" value="{{ csrf_token('markready' ~ dress.id) }}">
                        <button type="submit" class="btn btn-success">损坏已修复，安排清洗</button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="card">
    <h2>📜 租赁历史</h2>
    {% if dress.rentals is empty %}
    <p>暂无租赁记录。</p>
    {% else %}
    <table>
        <thead>
            <tr>
                <th>租单号</th>
                <th>客户</th>
                <th>出租日期</th>
                <th>应还日期</th>
                <th>归还日期</th>
                <th>押金</th>
                <th>损坏扣款</th>
                <th>状态</th>
            </tr>
        </thead>
        <tbody>
            {% for rental in dress.rentals|reverse %}
            <tr>
                <td><a href="{{ path('app_rental_show', {id: rental.id}) }}">#{{ rental.id }}</a></td>
                <td>{{ rental.customer.name }} ({{ rental.customer.phone }})</td>
                <td>{{ rental.rentalDate|date('Y-m-d') }}</td>
                <td>{{ rental.dueDate|date('Y-m-d') }}</td>
                <td>{{ rental.returnDate ? rental.returnDate|date('Y-m-d') : '-' }}</td>
                <td>¥{{ rental.depositPaid }}</td>
                <td>{{ rental.damageDeduction ? '¥' ~ rental.damageDeduction : '-' }}</td>
                <td>
                    {% if rental.status == 'rented' %}
                        <span class="badge badge-rented">{{ rental.statusLabel }}</span>
                    {% elseif rental.status == 'overdue' %}
                        <span class="badge badge-overdue">{{ rental.statusLabel }}</span>
                    {% elseif rental.status == 'returned' %}
                        <span class="badge badge-cleaning">{{ rental.statusLabel }}</span>
                    {% else %}
                        <span class="badge badge-available">{{ rental.statusLabel }}</span>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

<div class="card">
    <h2>🧺 清洗记录</h2>
    {% if dress.cleaningRecords is empty %}
    <p>暂无清洗记录。</p>
    {% else %}
    <table>
        <thead>
            <tr>
                <th>编号</th>
                <th>关联租单</th>
                <th>安排时间</th>
                <th>开始时间</th>
                <th>完成时间</th>
                <th>状态</th>
            </tr>
        </thead>
        <tbody>
            {% for record in dress.cleaningRecords|reverse %}
            <tr>
                <td>#{{ record.id }}</td>
                <td>{{ record.rental ? '#' ~ record.rental.id : '-' }}</td>
                <td>{{ record.scheduledAt|date('Y-m-d H:i') }}</td>
                <td>{{ record.startedAt ? record.startedAt|date('Y-m-d H:i') : '-' }}</td>
                <td>{{ record.completedAt ? record.completedAt|date('Y-m-d H:i') : '-' }}</td>
                <td>
                    <span class="badge badge-cleaning">{{ record.statusLabel }}</span>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>
{% endblock %}
