{% extends 'base.html.twig' %}

{% block title %}登记新服装 - {{ parent() }}{% endblock %}

{% block body %}
<div class="card">
    <h2>➕ 登记新服装</h2>
    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.name) }}
            {{ form_widget(form.name) }}
        </div>
        <div class="form-group">
            {{ form_label(form.size) }}
            {{ form_widget(form.size) }}
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.color) }}
            {{ form_widget(form.color) }}
        </div>
        <div class="form-group">
            {{ form_label(form.status) }}
            {{ form_widget(form.status) }}
        </div>
    </div>

    <div class="form-row">
        <div class="form-group">
            {{ form_label(form.purchasePrice) }}
            {{ form_widget(form.purchasePrice) }}
        </div>
        <div class="form-group">
            {{ form_label(form.deposit) }}
            {{ form_widget(form.deposit) }}
        </div>
        <div class="form-group">
            {{ form_label(form.dailyRate) }}
            {{ form_widget(form.dailyRate) }}
        </div>
    </div>

    <div class="form-group">
        {{ form_label(form.photoFile) }}
        {{ form_widget(form.photoFile) }}
        <small style="color:#666">支持 JPG/PNG/GIF/WEBP，最大 5MB</small>
    </div>

    <div style="margin-top:20px;">
        <button type="submit" class="btn btn-primary">保存登记</button>
        <a href="{{ path('app_dress_index') }}" class="btn btn-secondary">取消</a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
