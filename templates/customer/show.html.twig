{% extends 'base.html.twig' %}

{% block title %}{{ customer.name }} - 客户详情 - {{ parent() }}{% endblock %}

{% block body %}
<div class="card">
    <h2>👤 客户详情</h2>

    <div class="detail-grid">
        <div class="detail-item">
            <div class="label">姓名</div>
            <div class="value">{{ customer.name }}</div>
        </div>
        <div class="detail-item">
            <div class="label">手机号</div>
            <div class="value">{{ customer.phone ?: '未填写' }}</div>
        </div>
        <div class="detail-item">
            <div class="label">身份证号</div>
            <div class="value">{{ customer.idCard ?: '未填写' }}</div>
        </div>
        <div class="detail-item">
            <div class="label">住址</div>
            <div class="value">{{ customer.address ?: '未填写' }}</div>
        </div>
        <div class="detail-item">
            <div class="label">注册时间</div>
            <div class="value">{{ customer.createdAt|date('Y-m-d H:i') }}</div>
        </div>
        <div class="detail-item">
            <div class="label">账户余额</div>
            <div class="value" style="font-size:20px;color:#28a745;font-weight:bold;">
                ¥{{ balance }}
            </div>
        </div>
    </div>
</div>

<div class="card">
    <h2>💰 账户充值</h2>
    <form method="post" action="{{ path('app_customer_recharge', {id: customer.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('recharge' ~ customer.id) }}">
        <div class="form-row">
            <div class="form-group">
                <label>充值金额 (¥)</label>
                <input type="number" step="0.01" min="0.01" name="amount" placeholder="请输入充值金额" required>
            </div>
            <div class="form-group">
                <label>备注（可选）</label>
                <input type="text" name="description" placeholder="例如：预存、活动赠送等">
            </div>
        </div>
        <button type="submit" class="btn btn-primary" onclick="return confirm('确认充值？')">确认充值</button>
    </form>
</div>

<div class="card">
    <h2>📋 账户流水</h2>
    {% if transactions is empty %}
    <p>暂无交易记录。</p>
    {% else %}
    <table>
        <thead>
            <tr>
                <th>时间</th>
                <th>类型</th>
                <th>金额</th>
                <th>余额</th>
                <th>说明</th>
            </tr>
        </thead>
        <tbody>
            {% for tx in transactions %}
            <tr>
                <td>{{ tx.createdAt|date('Y-m-d H:i') }}</td>
                <td>
                    {% if tx.type == 'recharge' %}
                    <span class="badge badge-available">{{ tx.typeLabel }}</span>
                    {% elseif tx.type == 'freeze' %}
                    <span class="badge badge-rented">{{ tx.typeLabel }}</span>
                    {% elseif tx.type == 'unfreeze' %}
                    <span class="badge badge-cleaning">{{ tx.typeLabel }}</span>
                    {% elseif tx.type == 'damage_deduction' %}
                    <span class="badge badge-damaged">{{ tx.typeLabel }}</span>
                    {% else %}
                    <span class="badge">{{ tx.typeLabel }}</span>
                    {% endif %}
                </td>
                <td style="{% if tx.isDebit %}color:#dc3545;{% else %}color:#28a745;{% endif %}font-weight:bold;">
                    {% if tx.isDebit %}-{% else %}+{% endif %}¥{{ tx.amount }}
                </td>
                <td>¥{{ tx.balanceAfter }}</td>
                <td>{{ tx.description }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

<div class="card">
    <h2>📝 租单记录</h2>
    {% if customer.rentals is empty %}
    <p>暂无租单记录。</p>
    {% else %}
    <table>
        <thead>
            <tr>
                <th>租单号</th>
                <th>服装</th>
                <th>出租日期</th>
                <th>应还日期</th>
                <th>押金</th>
                <th>支付方式</th>
                <th>状态</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            {% for rental in customer.rentals %}
            <tr>
                <td>#{{ rental.id }}</td>
                <td>{{ rental.dress.name ?: '服装已删除' }}</td>
                <td>{{ rental.rentalDate|date('Y-m-d') }}</td>
                <td>{{ rental.dueDate|date('Y-m-d') }}</td>
                <td>¥{{ rental.depositPaid }}</td>
                <td>{{ rental.depositMethodLabel }}</td>
                <td>
                    {% if rental.status == 'rented' %}
                    <span class="badge badge-rented">{{ rental.statusLabel }}</span>
                    {% elseif rental.status == 'overdue' %}
                    <span class="badge badge-overdue">{{ rental.statusLabel }}</span>
                    {% elseif rental.status == 'returned' %}
                    <span class="badge badge-cleaning">{{ rental.statusLabel }}</span>
                    {% else %}
                    <span class="badge badge-available">{{ rental.statusLabel }}</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_rental_show', {id: rental.id}) }}" class="btn btn-sm btn-secondary">查看</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

<div style="margin-bottom:20px;">
    <a href="javascript:history.back()" class="btn btn-secondary">返回</a>
</div>
{% endblock %}
